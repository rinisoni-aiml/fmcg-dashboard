# Environment Variables
# Copy this to .env and fill in your values

# ===========================================
# GROQ API (Required for AI Chatbot)
# ===========================================
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ===========================================
# DATABASE (Optional but Recommended)
# ===========================================
# Option 1: Supabase (Recommended)
# Get free database at: https://supabase.com
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@db.your_project.supabase.co:5432/postgres

# Option 2: Neon
# Get free database at: https://neon.tech
# DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Option 3: Local PostgreSQL
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fmcg_saas

# Option 4: Supabase with separate URL and Key
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ===========================================
# APP SETTINGS
# ===========================================
DEBUG=True

# ===========================================
# DEPLOYMENT NOTES
# ===========================================
# For Streamlit Cloud:
# 1. Don't commit this file with real credentials
# 2. Add secrets in Streamlit Cloud dashboard
# 3. Use the "Advanced settings" → "Secrets" section
# 4. Format for Streamlit secrets (TOML):
#
# GROQ_API_KEY = "your_key_here"
# GROQ_MODEL = "llama-3.1-8b-instant"
# DATABASE_URL = "postgresql://..."
# DEBUG = "False"
